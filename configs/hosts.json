{
  "trendyol.com": {
    "default": {
      "field_extractors": {
        "price": {
          "selectors": [
            ".productDetailWrapper .new-price",
            ".productDetailWrapper .price .discounted"
          ],
          "required": true,
          "transforms": ["clean_text", "text_to_price"]
        },
        "old_price": {
          "selectors": [".productDetailWrapper .old-price"],
          "required": false,
          "transforms": ["clean_text", "text_to_price"]
        },
        "currency": {
          "selectors": [
            ".productDetailWrapper .new-price",
            ".productDetailWrapper .price .discounted",
            ".productDetailWrapper .old-price"
          ],
          "required": true,
          "transforms": [
            "clean_text",
            "to_lower",
            {"name": "text_contains", "search": "tl"},
            {"name": "true_to_text", "new": "TRY"}
          ]
        },
        "availability": {
          "selectors": [".productDetailWrapper .add-to-cart-button-text"],
          "transforms": [
            "clean_text",
            "to_lower",
            {"name": "text_contains", "search": "sepete ekle"}
          ]
        },
        "name": {
          "selectors": [
            ".productDetailWrapper .product-title",
            {"value": "meta[property='og:title']", "attribute": "content"}
          ],
          "transforms": ["clean_text"]
        },
        "image": {
          "selectors": [
            {"value": "meta[property='og:image']", "attribute": "content"}
          ],
          "transforms": ["clean_text"]
        }
      }
    }
  },
  "amazon.com.tr": {
    "default": {
      "wait_until": "load",
      "field_extractors": {
        "price": {
          "selectors": [
            {"value": "#priceValue", "attribute": "value"},
            {"value": "#addToCart input[name='items[0.base][customerVisiblePrice][amount]']", "attribute": "value"}
          ],
          "required": true,
          "transforms": ["clean_text", "text_to_price"]
        },
        "old_price": {
          "selectors": [
            "#corePriceDisplay_desktop_feature_div .basisPrice .a-offscreen",
            "#corePriceDisplay_desktop_feature_div .basisPrice span[aria-hidden='true']"
          ],
          "required": false,
          "transforms": ["clean_text", "text_to_price"]
        },
        "currency": {
          "selectors": [
            {"value": "#priceSymbol", "attribute": "value"},
            {"value": "#addToCart input[name='items[0.base][customerVisiblePrice][currencyCode]']", "attribute": "value"}
          ],
          "transforms": [
            "clean_text",
            "to_lower",
            {"name": "text_contains", "search": "try"},
            {"name": "true_to_text", "new": "TRY"}
          ]
        },
        "availability": {
          "selectors": [
            {"value": "#addToCart #add-to-cart-button", "attribute": "value"}
          ],
          "transforms": [
            "clean_text",
            "to_lower",
            {"name": "text_contains", "search": "sepete ekle"}
          ]
        },
        "name": {
          "selectors": [
            "#productTitle",
            {"value": "meta[name='title']", "attribute": "content"}
          ],
          "transforms": ["clean_text"]
        },
        "image": {
          "selectors": [
            {"value": "#imgTagWrapperId img#landingImage", "attribute": "data-old-hires"},
            {"value": "#imgTagWrapperId img#landingImage", "attribute": "src"}
          ],
          "transforms": ["clean_text"]
        }
      }
    }
  },
